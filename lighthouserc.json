{
  "ci": {
    "collect": {
      "staticDistDir": "./build",
      "url": [
        "/"
      ]
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.8 }],
        "categories:performance": ["warn", { "minScore": 0.5 }]
      }
    }
  }
}
